BINANCE_API_SECRET=your_testnet_secret_here
USE_TESTNET=true
DRY_RUN=true
RUN_ONCE=false
ENTRY_INTERVAL=1m
LEVERAGE=20
SMA_SHORT=7
SMA_LONG=25
TOP_N_SYMBOLS=3
VOLATILITY_INTERVAL=1h
